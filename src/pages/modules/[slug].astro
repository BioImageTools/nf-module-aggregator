---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import '../../styles/global.css';

import modules from '../../data/modules.json';

export function getStaticPaths() {
  return modules.map((module) => ({
    params: { slug: module.slug },
    props: { module },
  }));
}

// Helper to find a module by name (for component linking)
function findModule(name: string, currentSource: string): typeof modules[0] | null {
  // Normalize the component name for matching
  // Components may be listed as "spatial/nichecompasstraining" but modules are named "spatial_nichecompasstraining"
  const normalizedName = name.toLowerCase().replace(/\//g, '_');
  const nameWithoutPath = name.toLowerCase().split('/').pop() || name.toLowerCase();

  // First try to find in the same source with exact match
  let match = modules.find(m =>
    m.name.toLowerCase() === name.toLowerCase() && m.source === currentSource
  );
  if (match) return match;

  // Try with normalized name (slash -> underscore)
  match = modules.find(m =>
    m.name.toLowerCase() === normalizedName && m.source === currentSource
  );
  if (match) return match;

  // Try matching just the last part of the path
  match = modules.find(m =>
    m.name.toLowerCase().endsWith(nameWithoutPath) && m.source === currentSource
  );
  if (match) return match;

  // Fall back to any source with same matching strategies
  match = modules.find(m => m.name.toLowerCase() === name.toLowerCase());
  if (match) return match;

  match = modules.find(m => m.name.toLowerCase() === normalizedName);
  if (match) return match;

  match = modules.find(m => m.name.toLowerCase().endsWith(nameWithoutPath));
  return match || null;
}

// Extract org from repository URL
function getOrgFromRepo(repoUrl: string): string {
  const match = repoUrl.match(/github\.com\/([^\/]+)\//);
  return match ? match[1] : '';
}

interface Tool {
  name: string;
  description?: string;
  homepage?: string;
  documentation?: string;
  licence?: string;
}

interface IOSpec {
  name: string;
  type?: string;
  description?: string;
  pattern?: string;
}

interface Props {
  module: {
    name: string;
    slug: string;
    description: string;
    type: string;
    source: string;
    sourceLabel: string;
    repository: string;
    keywords?: string[];
    tools?: Tool[];
    components?: string[];
    authors?: string[];
    maintainers?: string[];
    inputs?: IOSpec[];
    outputs?: IOSpec[];
    version?: string;
  };
}

const { module } = Astro.props;
const base = import.meta.env.BASE_URL;
const org = getOrgFromRepo(module.repository);
const displayName = org ? `${org}/${module.name}` : module.name;
---

<BaseLayout title={`${displayName} - Nextflow Module Catalog`} description={module.description}>
  <Header />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12" data-pagefind-body>
    <!-- Breadcrumb -->
    <nav class="mb-8">
      <a href={base} class="text-blue-600 hover:text-blue-800 transition-colors">
        &larr; Back to Catalog
      </a>
    </nav>

    <!-- Module Header -->
    <header class="mb-8">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div class="flex-1">
          <div class="flex items-center gap-3 flex-wrap">
            <h1 class="text-3xl font-bold text-gray-900" data-pagefind-meta="title">
              {displayName}
            </h1>
            <span class={`inline-flex items-center px-2.5 py-1 rounded text-sm font-medium ${module.type === 'subworkflow' ? 'bg-purple-100 text-purple-700' : 'bg-blue-100 text-blue-700'}`}>
              {module.type}
            </span>
          </div>
          <p class="mt-3 text-lg text-gray-600" data-pagefind-meta="description">
            {module.description}
          </p>
        </div>

        {module.version && (
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
            v{module.version}
          </span>
        )}
      </div>

      <!-- Keywords -->
      {module.keywords && module.keywords.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {module.keywords.map((keyword) => (
            <span
              class="inline-flex items-center px-2.5 py-1 rounded-md text-sm font-medium bg-gray-100 text-gray-600"
              data-pagefind-filter="tag"
            >
              {keyword}
            </span>
          ))}
        </div>
      )}
    </header>

    <!-- Module Info -->
    <section class="bg-white rounded-lg border border-gray-200 p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Module Information</h2>

      <dl class="space-y-4">
        <div>
          <dt class="text-sm font-medium text-gray-500">Repository</dt>
          <dd class="mt-1">
            <a
              href={module.repository}
              target="_blank"
              rel="noopener noreferrer"
              class="text-blue-600 hover:text-blue-800 transition-colors break-all"
            >
              {module.repository}
            </a>
          </dd>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <dt class="text-sm font-medium text-gray-500">Source</dt>
            <dd class="mt-1 text-gray-900">{module.sourceLabel}</dd>
          </div>

          <div>
            <dt class="text-sm font-medium text-gray-500">Organization</dt>
            <dd class="mt-1 text-gray-900">{org}</dd>
          </div>

          {module.authors && module.authors.length > 0 && (
            <div>
              <dt class="text-sm font-medium text-gray-500">Authors</dt>
              <dd class="mt-1 text-gray-900">
                {module.authors.map((author, i) => (
                  <span>
                    <a
                      href={`https://github.com/${author}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-blue-600 hover:text-blue-800"
                    >
                      @{author}
                    </a>
                    {i < module.authors!.length - 1 && ', '}
                  </span>
                ))}
              </dd>
            </div>
          )}

          {module.maintainers && module.maintainers.length > 0 && (
            <div>
              <dt class="text-sm font-medium text-gray-500">Maintainers</dt>
              <dd class="mt-1 text-gray-900">
                {module.maintainers.map((maintainer, i) => (
                  <span>
                    <a
                      href={`https://github.com/${maintainer}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-blue-600 hover:text-blue-800"
                    >
                      @{maintainer}
                    </a>
                    {i < module.maintainers!.length - 1 && ', '}
                  </span>
                ))}
              </dd>
            </div>
          )}
        </div>
      </dl>
    </section>

    <!-- Components (for subworkflows) -->
    {module.components && module.components.length > 0 && (
      <section class="bg-white rounded-lg border border-gray-200 p-6 mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Components</h2>
        <p class="text-sm text-gray-600 mb-4">This subworkflow uses the following modules:</p>
        <div class="flex flex-wrap gap-2">
          {module.components.map((component) => {
            const linkedModule = findModule(component, module.source);
            if (linkedModule) {
              const isSubworkflow = linkedModule.type === 'subworkflow';
              return (
                <a
                  href={`${base}modules/${linkedModule.slug}/`}
                  class={`inline-flex items-center px-3 py-1.5 rounded-md text-sm font-medium transition-colors ${isSubworkflow ? 'bg-purple-50 text-purple-700 hover:bg-purple-100' : 'bg-blue-50 text-blue-700 hover:bg-blue-100'}`}
                >
                  {component}
                </a>
              );
            } else {
              return (
                <span class="inline-flex items-center px-3 py-1.5 rounded-md text-sm font-medium bg-gray-50 text-gray-500">
                  {component}
                </span>
              );
            }
          })}
        </div>
      </section>
    )}

    <!-- Tools -->
    {module.tools && module.tools.length > 0 && (
      <section class="bg-white rounded-lg border border-gray-200 p-6 mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Tools</h2>
        <div class="space-y-4">
          {module.tools.map((tool) => (
            <div class="border-l-4 border-blue-400 pl-4">
              <h3 class="font-medium text-gray-900">
                {tool.homepage ? (
                  <a
                    href={tool.homepage}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-blue-600 hover:text-blue-800"
                  >
                    {tool.name}
                  </a>
                ) : (
                  tool.name
                )}
              </h3>
              {tool.description && (
                <p class="mt-1 text-sm text-gray-600">{tool.description}</p>
              )}
              {tool.licence && (
                <p class="mt-1 text-xs text-gray-500">License: {tool.licence}</p>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Inputs -->
    {module.inputs && module.inputs.length > 0 && (
      <section class="bg-white rounded-lg border border-gray-200 p-6 mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Inputs</h2>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead>
              <tr>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              {module.inputs.map((input) => (
                <tr>
                  <td class="px-4 py-3 text-sm font-mono text-gray-900 whitespace-nowrap">{input.name}</td>
                  <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap">
                    {input.type && (
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-700">
                        {input.type}
                      </span>
                    )}
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-600">{input.description}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <!-- Outputs -->
    {module.outputs && module.outputs.length > 0 && (
      <section class="bg-white rounded-lg border border-gray-200 p-6 mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Outputs</h2>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead>
              <tr>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              {module.outputs.map((output) => (
                <tr>
                  <td class="px-4 py-3 text-sm font-mono text-gray-900 whitespace-nowrap">{output.name}</td>
                  <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap">
                    {output.type && (
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-700">
                        {output.type}
                      </span>
                    )}
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-600">{output.description}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <!-- Usage Section -->
    <section class="bg-white rounded-lg border border-gray-200 p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Quick Start</h2>

      <p class="text-gray-600 mb-4">
        Include this {module.type} in your Nextflow pipeline:
      </p>

      <pre class="bg-gray-900 text-gray-100 rounded-lg p-4 overflow-x-auto text-sm"><code>include {'{'} {module.name.toUpperCase().replace(/-/g, '_')} {'}'} from '{module.repository}'</code></pre>
    </section>

    <!-- Actions -->
    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href={module.repository}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 transition-colors"
      >
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
        View on GitHub
      </a>

      <a
        href={`${module.repository}/issues`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors"
      >
        Report Issue
      </a>
    </div>
  </main>
</BaseLayout>
