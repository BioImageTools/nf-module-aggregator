---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Catalog of Nextflow modules for bioimaging workflows' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>

    <!-- Pagefind UI -->
    <link href={`${base}pagefind/pagefind-ui.css`} rel="stylesheet" />
    <script is:inline define:vars={{ base }}>
      window.pagefindBasePath = base;
    </script>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900">
    <slot />

    <!-- Pagefind UI Script -->
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        const script = document.createElement('script');
        script.src = window.pagefindBasePath + 'pagefind/pagefind-ui.js';
        script.onload = () => {
          new PagefindUI({
            element: '#search',
            showSubResults: true,
            showImages: false,
            baseUrl: window.pagefindBasePath,
          });
        };
        document.head.appendChild(script);
      });
    </script>
  </body>
</html>
