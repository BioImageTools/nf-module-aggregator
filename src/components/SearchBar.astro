---
// SearchBar component - Pagefind search integration
// The actual search functionality is initialized via script in BaseLayout.astro
---

<div class="w-full max-w-2xl mx-auto">
  <div id="search" class="pagefind-ui" data-pagefind-ignore></div>
</div>

<style>
  /* Additional search bar styling */
  .pagefind-ui :global(.pagefind-ui__search-input) {
    padding: 0.75rem 1rem;
    font-size: 1rem;
  }

  .pagefind-ui :global(.pagefind-ui__search-clear) {
    padding: 0.75rem;
  }
</style>
