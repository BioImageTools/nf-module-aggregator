---
interface Props {
  name: string;
  org: string;
  description: string;
  repository: string;
  version?: string;
  tags?: string[];
  slug: string;
  type?: string;
  searchText?: string;
}

const { name, org, description, repository, version, tags = [], slug, type, searchText = '' } = Astro.props;
const base = import.meta.env.BASE_URL;
const displayName = org ? `${org}/${name}` : name;
---

<article
  class="module-card bg-white rounded-lg border border-gray-200 p-6 hover:border-blue-300"
    data-org={org}
  data-type={type}
  data-searchtext={searchText}
>
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <h3 class="text-lg font-semibold text-gray-900 truncate">
          <a href={`${base}modules/${slug}/`} class="hover:text-blue-600 transition-colors">
            {displayName}
          </a>
        </h3>
        {type && (
          <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${type === 'subworkflow' ? 'bg-purple-100 text-purple-700' : 'bg-blue-100 text-blue-700'}`}>
            {type}
          </span>
        )}
      </div>

      <p class="mt-2 text-gray-600 text-sm line-clamp-2">
        {description}
      </p>

      {tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {tags.slice(0, 4).map((tag) => (
            <span
              class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-gray-100 text-gray-600"
                          >
              {tag}
            </span>
          ))}
          {tags.length > 4 && (
            <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-gray-100 text-gray-500">
              +{tags.length - 4} more
            </span>
          )}
        </div>
      )}
    </div>

    {version && (
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
        v{version}
      </span>
    )}
  </div>

  <div class="mt-4 pt-4 border-t border-gray-100 flex items-center justify-between text-sm">
    <a
      href={repository}
      target="_blank"
      rel="noopener noreferrer"
      class="text-gray-500 hover:text-gray-700 transition-colors flex items-center gap-1"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
      </svg>
      <span>View Source</span>
    </a>

    <a
      href={`${base}modules/${slug}/`}
      class="text-blue-600 hover:text-blue-800 font-medium transition-colors"
    >
      Details &rarr;
    </a>
  </div>
</article>
